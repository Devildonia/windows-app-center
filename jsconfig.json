{
    "compilerOptions": {
        "target": "es2022",
        "module": "esnext",
        "moduleResolution": "node",
        "checkJs": true,
        "strict": false,
        "allowJs": true,
        "baseUrl": ".",
        "paths": {
            "*": [
                "*"
            ]
        }
    },
    "include": [
        "js/**/*",
        "main.js",
        "ragdoll.js",
        "sw.js"
    ],
