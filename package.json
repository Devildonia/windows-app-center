{
  "name": "windows-app-center",
  "version": "1.6.5",
  "type": "module",
  "description": "Windows 95 style simulator and prototyping environment. A sandbox for developing modular features (VFS, 3D Physics) ported to other projects.",
  "main": "main.ts",
  "scripts": {
    "dev": "vite",
    "test": "vitest",
    "test:run": "vitest run --reporter=verbose",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint js/ main.ts",
    "lint:fix": "eslint js/ main.ts --fix",
    "typecheck": "tsc --noEmit",
    "build": "npm run build:games && vite build",
    "build:games": "npx tailwindcss -i tailwind-games.css -o public/css/tailwind-games.css --content \"./public/games/**/*.html\" --minify",
    "generate:app": "node scripts/create-app.js",
    "preview": "vite preview"
  },
  "keywords": [
    "windows95",
    "retro",
    "desktop",
    "vite",
    "prototyping",
    "sandbox",
    "3d-physics"
  ],
  "author": "HaDeS (A.K.A. DeViLDoNia)",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.16",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^15.0.0",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.0.18"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@types/three": "^0.183.1",
    "three": "^0.183.2"
  }
}
